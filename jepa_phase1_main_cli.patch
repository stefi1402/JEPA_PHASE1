From 935abfe1090cbff1381a9d4caa85ac3e73e85016 Mon Sep 17 00:00:00 2001
From: a <a@a.com>
Date: Mon, 13 Jul 2026 07:01:02 +0000
Subject: [PATCH] Add
 --gsheet_enabled/--gsheet_id/--gsheet_creds/--gsheet_worksheet flags to
 evaluate and generalize

---
 main.py | 23 +++++++++++++++++++++++
 1 file changed, 23 insertions(+)

diff --git a/main.py b/main.py
index 234b61d..065399d 100644
--- a/main.py
+++ b/main.py
@@ -45,6 +45,7 @@ from dataset import generate_dataset, save_dataset
 import viz
 import train as train_mod
 import evaluate as eval_mod
+from sheets_logger import GSHEET_ENABLED, GSHEET_ID, GSHEET_CREDS_PATH, GSHEET_WORKSHEET
 
 
 def cmd_generate(args):
@@ -109,6 +110,10 @@ def cmd_evaluate(args):
         seed=args.seed,
         batch_size=args.batch_size,
         num_workers=args.num_workers,
+        gsheet_enabled=args.gsheet_enabled,
+        gsheet_id=args.gsheet_id,
+        gsheet_creds=args.gsheet_creds,
+        gsheet_worksheet=args.gsheet_worksheet,
     )
 
 
@@ -122,6 +127,10 @@ def cmd_generalize(args):
         seed=args.seed,
         batch_size=args.batch_size,
         num_workers=args.num_workers,
+        gsheet_enabled=args.gsheet_enabled,
+        gsheet_id=args.gsheet_id,
+        gsheet_creds=args.gsheet_creds,
+        gsheet_worksheet=args.gsheet_worksheet,
     )
 
 
@@ -183,6 +192,13 @@ def build_parser():
                     help="keep this small: sequence length is t_obs*d*d + t_future tokens, "
                          "so attention memory grows fast with batch_size")
     e.add_argument("--num_workers", type=int, default=2, help="DataLoader worker processes")
+    e.add_argument("--gsheet_enabled", action="store_true", default=GSHEET_ENABLED,
+                    help="log this evaluation's metrics as a row to a Google Sheet "
+                         "(see sheets_logger.py for one-time setup)")
+    e.add_argument("--no_gsheet", dest="gsheet_enabled", action="store_false")
+    e.add_argument("--gsheet_id", type=str, default=GSHEET_ID)
+    e.add_argument("--gsheet_creds", type=str, default=GSHEET_CREDS_PATH)
+    e.add_argument("--gsheet_worksheet", type=str, default=GSHEET_WORKSHEET)
 
     # ---- generalize ----
     gen = sub.add_parser("generalize", help="sweep p (and k) to study generalization / sensitivity")
@@ -194,6 +210,13 @@ def build_parser():
     gen.add_argument("--seed", type=int, default=123)
     gen.add_argument("--batch_size", type=int, default=4)
     gen.add_argument("--num_workers", type=int, default=2, help="DataLoader worker processes")
+    gen.add_argument("--gsheet_enabled", action="store_true", default=GSHEET_ENABLED,
+                       help="log each (p,k) combo's metrics as a row to a Google Sheet "
+                            "(see sheets_logger.py for one-time setup)")
+    gen.add_argument("--no_gsheet", dest="gsheet_enabled", action="store_false")
+    gen.add_argument("--gsheet_id", type=str, default=GSHEET_ID)
+    gen.add_argument("--gsheet_creds", type=str, default=GSHEET_CREDS_PATH)
+    gen.add_argument("--gsheet_worksheet", type=str, default=GSHEET_WORKSHEET)
 
     return parser
 
-- 
