+"""
+sheets_logger.py
+================
+Append sweep-dkt results to a Google Sheet, one row per finished config.
+
+Columns written (in this order):
+  grid | d_model | k | T | p_true | p_move_hat | k_true |
+  exp_step_dist_true | exp_step_dist_hat | coord_loss | coord_acc
+
+The first 4 columns are the parameters being swept; the last 7 are
+exactly the fields analyze.estimate_p_and_k() returns.
+
+--------------------------------------------------------------------------
+ONE-TIME SETUP (needed once, not per run):
+  1. Go to https://console.cloud.google.com/ and create a project (or
+     reuse an existing one).
+  2. In "APIs & Services" -> "Library", enable the "Google Sheets API".
+  3. Go to "APIs & Services" -> "Credentials" -> "Create Credentials" ->
+     "Service Account". Give it any name, no special roles needed.
+  4. Open the new service account -> "Keys" -> "Add Key" -> "Create new
+     key" -> JSON. This downloads a .json credentials file -- save it
+     somewhere on disk, e.g. ~/gsheet_creds.json (do NOT commit this to
+     git, it's a secret).
+  5. Open that JSON file and copy the "client_email" value (looks like
+     something@your-project.iam.gserviceaccount.com).
+  6. Open your Google Sheet -> "Share" -> paste that email address ->
+     give it "Editor" access -> Share.
+  7. Install the two packages this needs:
+       uv add gspread google-auth
+     (or: pip install gspread google-auth --break-system-packages)
+  8. In config.py, set GSHEET["enabled"] = True, GSHEET["sheet_id"] to
+     the ID from your sheet's URL (the long string between /d/ and
+     /edit), and GSHEET["creds_path"] to the path of the JSON file from
+     step 4.
+--------------------------------------------------------------------------
+"""
+
+HEADER = ["grid", "d_model", "k", "T", "p_true", "p_move_hat", "k_true",
+          "exp_step_dist_true", "exp_step_dist_hat", "coord_loss", "coord_acc"]
+
+_worksheet_cache = {}
+
+
+def _get_worksheet(sheet_id, creds_path, worksheet_name="Sheet1"):
+    import gspread
+    from google.oauth2.service_account import Credentials
+
+    key = (sheet_id, creds_path, worksheet_name)
+    if key in _worksheet_cache:
+        return _worksheet_cache[key]
+
+    scopes = ["https://www.googleapis.com/auth/spreadsheets"]
+    creds = Credentials.from_service_account_file(creds_path, scopes=scopes)
+    gc = gspread.authorize(creds)
+    sh = gc.open_by_key(sheet_id)
+    try:
+        ws = sh.worksheet(worksheet_name)
+    except gspread.WorksheetNotFound:
+        ws = sh.sheet1
+
+    existing = ws.get_all_values()
+    if not existing:
+        ws.append_row(HEADER)
+
+    _worksheet_cache[key] = ws
+    return ws
+
+
+def log_result(sheet_id, creds_path, grid, d_model, k, T, diag, worksheet_name="Sheet1"):
+    """diag: the dict returned by analyze.estimate_p_and_k -- must contain
+    p_true, p_move_hat, k_true, exp_step_dist_true, exp_step_dist_hat,
+    coord_loss, coord_acc. Never raises -- logs and prints a warning
+    instead, so a Sheets hiccup never kills a long-running sweep."""
+    try:
+        ws = _get_worksheet(sheet_id, creds_path, worksheet_name)
+        row = [grid, d_model, k, T,
+               diag.get("p_true"), diag.get("p_move_hat"), diag.get("k_true"),
+               diag.get("exp_step_dist_true"), diag.get("exp_step_dist_hat"),
+               diag.get("coord_loss"), diag.get("coord_acc")]
+        ws.append_row(row)
+        print(f"           logged to Google Sheet: grid={grid} d_model={d_model} k={k} T={T}")
+    except ImportError:
+        print("           [WARN] gspread/google-auth not installed -- skipping Sheet log. "
+              "Run: uv add gspread google-auth")
+    except Exception as e:
+        print(f"           [WARN] failed to log to Google Sheet: {e}")
